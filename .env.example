# ─────────────────────────────────────────────────────────────────────────────
# ARCHIVO DE EJEMPLO DE VARIABLES DE ENTORNO
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores reales en .env
#   3. NUNCA subas .env al repositorio (ya está en .gitignore)
#   4. En CI/CD usa variables de entorno secretas (GitHub Secrets, GitLab Variables)
# ─────────────────────────────────────────────────────────────────────────────

# ─── URL de la aplicación bajo prueba ────────────────────────────────────────
# Apunta a la instancia que quieres probar.
# Ejemplos: https://www.saucedemo.com | https://staging.saucedemo.com
BASE_URL=https://www.saucedemo.com

# ─── Usuario estándar de SauceDemo ───────────────────────────────────────────
# Tiene acceso completo a todas las funcionalidades de la tienda
STANDARD_USER=standard_user

# ─── Usuario bloqueado de SauceDemo ──────────────────────────────────────────
# Este usuario es rechazado en el login — útil para tests de casos negativos
LOCKED_USER=locked_out_user

# ─── Contraseña compartida de SauceDemo ──────────────────────────────────────
# En producción real esta credencial viviría en un vault (HashiCorp, AWS Secrets)
PASSWORD=secret_sauce
